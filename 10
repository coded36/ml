import numpy as np
import pandas as pd
import matplotlib.pyplot as plt

# Gaussian Kernel
def kernel(point, xmat, k):
    m, n = np.shape(xmat)
    weights = np.mat(np.eye(m))
    
    for j in range(m):
        diff = point - xmat[j]   # FIXED (was X[j])
        weights[j, j] = np.exp(diff * diff.T / (-2.0 * k**2))
    
    return weights

# Compute local weights (theta)
def localWeight(point, xmat, ymat, k):
    wei = kernel(point, xmat, k)
    XTWX = xmat.T * (wei * xmat)
    XTWX_inv = XTWX.I
    W = XTWX_inv * (xmat.T * (wei * ymat.T))
    return W

# Perform regression for all points
def localWeightRegression(xmat, ymat, k):
    m, n = np.shape(xmat)
    ypred = np.zeros(m)
    
    for i in range(m):
        ypred[i] = xmat[i] * localWeight(xmat[i], xmat, ymat, k)
    
    return ypred

# Load data
data = pd.read_csv('LR.csv')

colA = np.array(data['colA'])
colB = np.array(data['colB'])

# Convert to matrix
mcolA = np.mat(colA)
mcolB = np.mat(colB)

m = np.shape(mcolA)[1]

# Add bias term (1s column)
one = np.ones((m, 1))
X = np.hstack((one, mcolA.T))

print(X.shape)

# Set bandwidth parameter k
ypred = localWeightRegression(X, mcolB, 0.5)

# Sorting for smooth plotting
SortIndex = np.argsort(X[:, 1], axis=0)
xsort = X[SortIndex][:, 0]

# Plot
fig = plt.figure()
ax = fig.add_subplot(1, 1, 1)

ax.scatter(colA, colB, color='green')
ax.plot(X[SortIndex][:, 1], ypred[SortIndex], color='red', linewidth=3)

plt.xlabel('colA')
plt.ylabel('colB')
plt.show()
